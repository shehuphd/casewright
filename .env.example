# LLM provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# Your API key for the selected provider
LLM_API_KEY=

# Model names (adjust to your preference)
LLM_TEXT_MODEL=gpt-4.1-mini
LLM_VISION_MODEL=gpt-4.1-mini

# Absolute path to the evidence documents directory
# Defaults to data/documents/ inside the project if not set
DOCUMENTS_DIR=
